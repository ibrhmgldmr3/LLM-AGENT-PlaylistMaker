GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-3-flash-preview

YOUTUBE_SEARCH_PER_TOPIC=8
TRANSCRIPT_SCORE_TOP_K=3
REQUEST_TIMEOUT_SEC=30
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_SEC=1.0

# Wait duration after detected 429/rate-limit in yt-dlp paths
YTDLP_RATE_LIMIT_COOLDOWN_SEC=20

# Optional: yt-dlp anti-rate-limit/auth settings
# Examples:
# YTDLP_COOKIES_FROM_BROWSER=chrome
# YTDLP_COOKIES_FROM_BROWSER=firefox:default
YTDLP_COOKIES_FROM_BROWSER=
# Or use an exported Netscape cookie file
YTDLP_COOKIES_FILE=
# Optional proxy (http/socks)
YTDLP_PROXY=

# Optional: set if ffmpeg is not on PATH
FFMPEG_PATH=

# Required for whisper.cpp fallback
# Build whisper.cpp to get whisper-cli, then set the full path here.
WHISPER_CPP_CLI_PATH=C:\projeler\keyfi\make_a_playlist\whisper.cpp\build\bin\whisper-cli.exe
WHISPER_CPP_MODEL_PATH=C:\projeler\keyfi\make_a_playlist\whisper.cpp\models\ggml-base.bin
