GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Primary discovery path. Leave blank to use yt-dlp fallback only.
YOUTUBE_DATA_API_KEY=

# Optional official playlist creation.
YOUTUBE_OAUTH_CLIENT_SECRET_FILE=
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_TOKEN_FILE=data/cache/youtube_oauth_token.json

# ASR backend selection: auto | faster-whisper | whisper.cpp
ASR_BACKEND=auto
FASTER_WHISPER_MODEL_SIZE=base
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8
ALLOW_UNSAFE_OPENMP_WORKAROUND=true
WHISPER_CPP_CLI_PATH=whisper.cpp/build/bin/whisper-cli.exe
WHISPER_CPP_MODEL_PATH=whisper.cpp/models/ggml-base.bin

# Optional if ffmpeg is not on PATH
FFMPEG_PATH=
YTDLP_PROXY=
YTDLP_COOKIES_FROM_BROWSER=
YTDLP_COOKIES_FILE=
YTDLP_JS_RUNTIME=node

DATA_DIR=data
SQLITE_PATH=data/cache/app.db

SEARCH_CANDIDATES_PER_SUBTOPIC=12
METADATA_TOP_K=4
REQUEST_TIMEOUT_SEC=30
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_SEC=1.0
